{
  "version": "2026-07",
  "analysisEngine": "texttraits-email-quality-rules/2026-07",
  "commonOutputFields": [
    "texttraits_request_id",
    "texttraits_content_hash",
    "texttraits_score",
    "texttraits_gate",
    "texttraits_route",
    "texttraits_send_ready",
    "texttraits_next_step",
    "texttraits_owner_queue",
    "texttraits_blocker_level",
    "texttraits_blocker_reason",
    "texttraits_policy_version",
    "texttraits_analysis_engine"
  ],
  "components": {
    "src/app/cards/texttraits-email-fit-card-hsmeta.json": {
      "type": "card",
      "entrypoint": "/app/cards/TextTraitsEmailFitCard.jsx",
      "backendEndpoints": [
        "/v1/integrations/hubspot/analyze-and-sync",
        "/v1/integrations/hubspot/review-action"
      ]
    },
    "src/app/home/texttraits-home-hsmeta.json": {
      "type": "home",
      "entrypoint": "/app/home/TextTraitsHome.jsx",
      "backendEndpoints": [
        "/v1/integrations/hubspot/app-home/bootstrap",
        "/v1/integrations/hubspot/campaigns/review"
      ]
    },
    "src/app/settings/texttraits-settings-hsmeta.json": {
      "type": "settings",
      "entrypoint": "/app/settings/TextTraitsSettings.jsx",
      "backendEndpoints": [
        "/v1/integrations/hubspot/settings/bootstrap",
        "/v1/integrations/hubspot/properties/provision",
        "/v1/integrations/hubspot/analysis-schema/provision"
      ]
    }
  },
  "backendEndpoints": [
    "/v1/integrations/hubspot/crm-card/analyze-email",
    "/v1/integrations/hubspot/workflow-actions/analyze-email",
    "/v1/integrations/hubspot/workflow-actions/analyze-asset-copy",
    "/v1/integrations/hubspot/workflow-actions/review-campaign-assets",
    "/v1/integrations/hubspot/analyze-and-sync",
    "/v1/integrations/hubspot/app-home/bootstrap",
    "/v1/integrations/hubspot/settings/bootstrap",
    "/v1/integrations/hubspot/review-action",
    "/v1/integrations/hubspot/outcomes",
    "/v1/integrations/hubspot/webhooks/receive",
    "/v1/integrations/hubspot/app-uninstalled"
  ],
  "workflowActions": {
    "src/app/workflow-actions/texttraits-analyze-email-hsmeta.json": {
      "endpoint": "/v1/integrations/hubspot/workflow-actions/analyze-email",
      "requiredInputs": ["email_subject", "email_body"],
      "requiredOutputs": ["texttraits_score", "texttraits_gate", "texttraits_route", "texttraits_request_id", "texttraits_content_hash", "texttraits_analysis_engine"]
    },
    "src/app/workflow-actions/texttraits-analyze-asset-copy-hsmeta.json": {
      "endpoint": "/v1/integrations/hubspot/workflow-actions/analyze-asset-copy",
      "requiredInputs": ["asset_type", "asset_id", "asset_name", "asset_copy", "campaign_id", "analysis_mode"],
      "requiredOutputs": ["texttraits_score", "texttraits_gate", "texttraits_route", "texttraits_asset_type", "texttraits_asset_id", "texttraits_asset_name", "texttraits_request_id", "texttraits_content_hash", "texttraits_analysis_engine"]
    },
    "src/app/workflow-actions/texttraits-analyze-and-sync-hsmeta.json": {
      "endpoint": "/v1/integrations/hubspot/analyze-and-sync",
      "requiredInputs": ["email_subject", "email_body", "analysis_association_type_ids"],
      "requiredOutputs": ["texttraits_score", "texttraits_gate", "texttraits_sync_status", "texttraits_sync_actions", "texttraits_analysis_engine"]
    },
    "src/app/workflow-actions/texttraits-review-campaign-assets-hsmeta.json": {
      "endpoint": "/v1/integrations/hubspot/workflow-actions/review-campaign-assets",
      "requiredInputs": ["portal_id", "campaign_id", "asset_types"],
      "requiredOutputs": ["texttraits_campaign_health", "texttraits_gate", "texttraits_route", "texttraits_analyzed_count", "texttraits_blocked_count", "texttraits_copy_coverage", "texttraits_coverage_score", "texttraits_coverage_label"]
    }
  }
}
