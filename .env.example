TEXTTRAITS_SECRET_KEY=replace-with-a-long-random-secret
TEXTTRAITS_DB_PATH=/var/lib/texttraits/texttraits_workspace.sqlite3
TEXTTRAITS_DATABASE_URL=
# Preferred for hosted Postgres/Supabase. Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://texttraits:password@db.example.com:5432/texttraits
TEXTTRAITS_DB_SSLMODE=require
TEXTTRAITS_DB_CONNECT_TIMEOUT=10
TEXTTRAITS_PUBLIC_BASE_URL=https://your-domain.example
TEXTTRAITS_ALLOWED_PUBLIC_HOSTS=your-domain.example
TEXTTRAITS_EMAIL_PROVIDER=smtp
TEXTTRAITS_FROM_EMAIL=TextTraits <no-reply@your-domain.example>
TEXTTRAITS_SMTP_HOST=smtp.postmarkapp.com
TEXTTRAITS_SMTP_PORT=587
TEXTTRAITS_SMTP_USERNAME=
TEXTTRAITS_SMTP_PASSWORD=
TEXTTRAITS_SMTP_TLS=true
TEXTTRAITS_SENDGRID_API_KEY=
TEXTTRAITS_ALLOW_DEMO=false
TEXTTRAITS_DEV_ACCOUNT_LINKS=false
TEXTTRAITS_MAX_TEXT_WORDS=1800
TEXTTRAITS_MAX_CONTENT_LENGTH=1000000
TEXTTRAITS_MAX_WORKSPACE_BYTES=500000
TEXTTRAITS_MAX_EVENT_BYTES=12000
TEXTTRAITS_RATE_LIMIT_PER_MINUTE=80
TEXTTRAITS_SECURE_COOKIES=true
TEXTTRAITS_TRUST_PROXY=true
TEXTTRAITS_LOG_JSON=true
TEXTTRAITS_LOG_LEVEL=INFO
TEXTTRAITS_LOG_MAX_BYTES=10485760
TEXTTRAITS_LOG_BACKUPS=5
TEXTTRAITS_ENV=production
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
TEXTTRAITS_STORE_OAUTH_TOKENS=false
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
OUTREACH_CLIENT_ID=
OUTREACH_CLIENT_SECRET=
SALESLOFT_CLIENT_ID=
SALESLOFT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
ENABLE_DEV_TOOLS=false
HOST=0.0.0.0
PORT=8000
